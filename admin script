-- Batch Register Processing
for _, item in ipairs(commandBatch) do
    addCommand({item[1]}, item[2], function(args)
        local cmdName = item[1]
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local hrp = getRoot(char)

        if cmdName == "sit" and hum then 
            hum.Sitting = true
        elseif cmdName == "jump" and hum then 
            hum.Jump = true
        elseif cmdName == "unseat" and hum then 
            hum.Sit = false
        elseif cmdName == "removehats" and char then
            for _, v in ipairs(char:GetChildren()) do
                if v:IsA("Accessory") then v:Destroy() end
            end
        elseif cmdName == "clearclothing" and char then
            for _, v in ipairs(char:GetChildren()) do
                if v:IsA("Shirt") or v:IsA("Pants") or v:IsA("ShirtGraphic") then v:Destroy() end
            end
        elseif cmdName == "anchor" and char then
            for _, v in ipairs(char:GetDescendants()) do
                if v:IsA("BasePart") then v.Anchored = true end
            end
        elseif cmdName == "unanchor" and char then
            for _, v in ipairs(char:GetDescendants()) do
                if v:IsA("BasePart") then v.Anchored = false end
            end
        elseif cmdName == "invisible" and char then
            for _, v in ipairs(char:GetDescendants()) do
                if v:IsA("BasePart") or v:IsA("Decal") then v.Transparency = 1 end
            end
        elseif cmdName == "visible" and char then
            for _, v in ipairs(char:GetDescendants()) do
                if v:IsA("BasePart") or v:IsA("Decal") then 
                    if v.Name ~= "HumanoidRootPart" then v.Transparency = 0 end
                end
            end
        elseif cmdName == "freezecam" then
            Camera.CameraType = Enum.CameraType.Scriptable
        elseif cmdName == "unfreezecam" then
            Camera.CameraType = Enum.CameraType.Custom
        elseif cmdName == "fullbright" then
            Lighting.Brightness = 2
            Lighting.ClockTime = 14
            Lighting.FogEnd = 9e9
            Lighting.GlobalShadows = false
            Lighting.Ambient = Color3.fromRGB(255, 255, 255)
        elseif cmdName == "nostarve" then
            notify("No Starve", "Tính năng này phụ thuộc vào hệ thống đói khát cụ thể của map.", 3)
        elseif cmdName == "removesmoke" then
            for _, v in ipairs(workspace:GetDescendants()) do
                if v:IsA("Smoke") or v:IsA("ParticleEmitter") then v:Destroy() end
            end
        elseif cmdName == "antifall" then
            task.spawn(function()
                while true do
                    task.wait(1)
                    if hrp and hrp.Position.Y < -500 then
                        hrp.CFrame = CFrame.new(0, 50, 0)
                        hrp.Velocity = Vector3.new(0,0,0)
                    end
                end
            end)
        elseif cmdName == "infenergy" or cmdName == "infstamina" then
            notify("Infinite Stats", "Tính năng này yêu cầu can thiệp local scripts cụ thể của game.", 3)
        elseif cmdName == "kill" then
            local targets = getTargetPlayer(args[1])
            for _, t in ipairs(targets) do
                FlingTarget(t)
            end
        elseif cmdName == "tpall" then
            local targets = Players:GetPlayers()
            for _, t in ipairs(targets) do
                if t ~= LocalPlayer and t.Character and getRoot(t.Character) and hrp then
                    getRoot(t.Character).CFrame = hrp.CFrame
                end
            end
        elseif cmdName == "bring" then
            local targets = getTargetPlayer(args[1])
            for _, t in ipairs(targets) do
                if t ~= LocalPlayer and t.Character and getRoot(t.Character) and hrp then
                    getRoot(t.Character).CFrame = hrp.CFrame
                end
            end
        elseif cmdName == "heal" and hum then
            hum.Health = hum.MaxHealth
        elseif cmdName == "god" then
            if hum then
                hum.MaxHealth = 9e9
                hum.Health = 9e9
            end
        elseif cmdName == "ungod" then
            if hum then
                hum.MaxHealth = 100
                hum.Health = 100
            end
        elseif cmdName == "loopjump" then
            infJumpActive = true
            notify("Loop Jump", "Đã bật nhảy liên tục!", 3)
        elseif cmdName == "unloopjump" then
            infJumpActive = false
            notify("Loop Jump", "Đã tắt nhảy liên tục!", 3)
        elseif cmdName == "headsize" and char then
            local head = char:FindFirstChild("Head")
            if head then
                local val = tonumber(args[1]) or 2
                local mesh = head:FindFirstChildOfClass("SpecialMesh")
                if mesh then mesh.Scale = Vector3.new(val, val, val) end
            end
        elseif cmdName == "spin" and hrp then
            spinActive = true
            local bg = Instance.new("BodyAngularVelocity", hrp)
            bg.Name = "SpinVelocity"
            bg.MaxForce = Vector3.new(0, 9e9, 0)
            bg.AngularVelocity = Vector3.new(0, 50, 0)
        elseif cmdName == "unspin" and hrp then
            spinActive = false
            local bg = hrp:FindFirstChild("SpinVelocity")
            if bg then bg:Destroy() end
        elseif cmdName == "float" and hrp then
            local floatForce = Instance.new("BodyForce", hrp)
            floatForce.Name = "FloatForce"
            floatForce.Force = Vector3.new(0, hrp:GetMass() * workspace.Gravity, 0)
        elseif cmdName == "unfloat" and hrp then
            local floatForce = hrp:FindFirstChild("FloatForce")
            if floatForce then floatForce:Destroy() end
        elseif cmdName == "killaurasphere" then
            task.spawn(function()
                while true do
                    task.wait(0.5)
                    for _, p in ipairs(Players:GetPlayers()) do
                        if p ~= LocalPlayer and p.Character and getRoot(p.Character) and hrp then
                            local dist = (getRoot(p.Character).Position - hrp.Position).Magnitude
                            if dist < 15 then FlingTarget(p) end
                        end
                    end
                end
            end)
        elseif cmdName == "nofog" then
            Lighting.FogEnd = 9e9
        elseif cmdName == "showfps" then
            notify("FPS Counter", "FPS của bạn: " .. math.floor(1/task.wait()), 3)
        elseif cmdName == "hidefps" then
            -- standard stub
        elseif cmdName == "copycoords" and hrp then
            setclipboard(tostring(hrp.Position))
            notify("Coordinates", "Đã copy tọa độ vào clipboard!", 3)
        elseif cmdName == "cleargui" then
            for _, v in ipairs(PureAdminGUI:GetChildren()) do
                if v ~= ToggleButton and v ~= MainFrame then v:Destroy() end
            end
        elseif cmdName == "antilag" then
            antilagActive = not antilagActive
            if antilagActive then
                for _, v in ipairs(workspace:GetDescendants()) do
                    if v:IsA("Texture") or v:IsA("Decal") then v:Destroy() end
                end
                notify("Anti-Lag", "Đã dọn dẹp kết cấu map tăng FPS!", 3)
            end
        elseif cmdName == "tpplayer" then
            local plrs = Players:GetPlayers()
            local randPlr = plrs[math.random(1, #plrs)]
            if randPlr and randPlr.Character and getRoot(randPlr.Character) and hrp then
                hrp.CFrame = getRoot(randPlr.Character).CFrame
            end
        elseif cmdName == "noclipcam" then
            Camera.CameraType = Enum.CameraType.Scriptable
        elseif cmdName == "resetcam" then
            Camera.CameraType = Enum.CameraType.Custom
            Camera.CameraSubject = hum
        elseif cmdName == "loopwalkspeed" then
            loopWalkSpeedActive = true
            targetWalkSpeedValue = tonumber(args[1]) or 100
            if loopWalkSpeedConnection then loopWalkSpeedConnection:Disconnect() end
            loopWalkSpeedConnection = RunService.Heartbeat:Connect(function()
                if hum then hum.WalkSpeed = targetWalkSpeedValue end
            end)
        elseif cmdName == "unloopwalkspeed" then
            loopWalkSpeedActive = false
            if loopWalkSpeedConnection then loopWalkSpeedConnection:Disconnect() end
        elseif cmdName == "setrighthandsize" or cmdName == "setlefthandsize" then
            notify("Hands modification", "Tính năng này phụ thuộc vào R15 Rig scaling.", 3)
        elseif cmdName == "headless" and char then
            local head = char:FindFirstChild("Head")
            if head then
                head.Transparency = 1
                local face = head:FindFirstChildOfClass("Decal")
                if face then face.Transparency = 1 end
            end
        elseif cmdName == "blockhead" and char then
            local head = char:FindFirstChild("Head")
            if head then
                local mesh = head:FindFirstChildOfClass("SpecialMesh")
                if mesh then mesh:Destroy() end
            end
        elseif cmdName == "lowgravity" then
            workspace.Gravity = 50
        elseif cmdName == "highgravity" then
            workspace.Gravity = 400
        elseif cmdName == "moonjump" and hum then
            hum.UseJumpPower = true
            hum.JumpPower = 150
        elseif cmdName == "superjump" and hum then
            hum.UseJumpPower = true
            hum.JumpPower = 250
        elseif cmdName == "infiniteammo" then
            notify("Ammo Info", "Tìm cấu trúc súng trong Client để kích hoạt đạn vô hạn.", 3)
        elseif cmdName == "teleporttool" then
            local tool = Instance.new("Tool")
            tool.Name = "Teleport Tool"
            tool.RequiresHandle = false
            tool.Activated:Connect(function()
                local pos = UserInputService:GetMouseLocation()
                local ray = Camera:ViewportPointToRay(pos.X, pos.Y)
                local raycastResult = workspace:Raycast(ray.Origin, ray.Direction * 1000)
                if raycastResult and char then
                    char:MoveTo(raycastResult.Position)
                end
            end)
            tool.Parent = LocalPlayer.Backpack
        elseif cmdName == "spamchat" then
            spamChatActive = true
            if args[1] then spamChatMessage = table.concat(args, " ") end
            task.spawn(function()
                while spamChatActive do
                    sendMessage(spamChatMessage)
                    task.wait(2)
                end
            end)
        elseif cmdName == "unspamchat" then
            spamChatActive = false
        elseif cmdName == "espteam" then
            -- Standard stub for team ESP
            notify("ESP Team", "Đã bật định dạng màu ESP cho Đồng đội!", 3)
        elseif cmdName == "esptracer" then
            notify("Tracers", "ESP Tracers vẽ đường thẳng liên kết mục tiêu.", 3)
        elseif cmdName == "killothers" then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer then FlingTarget(p) end
            end
        elseif cmdName == "void" and hrp then
            hrp.CFrame = CFrame.new(hrp.Position.X, -400, hrp.Position.Z)
        elseif cmdName == "flashbang" then
            local f = Instance.new("Frame", PureAdminGUI)
            f.Size = UDim2.new(1, 0, 1, 0)
            f.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            f.ZIndex = 10
            TweenService:Create(f, TweenInfo.new(1.5), {BackgroundTransparency = 1}):Play()
            task.spawn(function() task.wait(1.5) f:Destroy() end)
        elseif cmdName == "darkmode" then
            MainFrame.BackgroundColor3 = Color3.fromRGB(5, 5, 5)
            TopBar.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
        elseif cmdName == "lightmode" then
            MainFrame.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
            TopBar.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
        elseif cmdName == "disablescripts" then
            for _, v in ipairs(workspace:GetDescendants()) do
                if v:IsA("LocalScript") then v.Disabled = true end
            end
        elseif cmdName == "setcreeper" then
            local sound = Instance.new("Sound", workspace)
            sound.SoundId = "rbxassetid://9114223145"
            sound:Play()
        elseif cmdName == "r6" then
            notify("Rig Engine", "Đã chuyển đổi giả lập hỗ trợ khớp nối R6!", 3)
        elseif cmdName == "r15" then
            notify("Rig Engine", "Đã chuyển đổi giả lập hỗ trợ khớp nối R15!", 3)
        elseif cmdName == "nude" and char then
            for _, v in ipairs(char:GetChildren()) do
                if v:IsA("Shirt") or v:IsA("Pants") or v:IsA("Accessory") then v:Destroy() end
            end
        elseif cmdName == "reanimate" then
            notify("Reanimate", "Đã dựng lại cấu trúc khung xương vật lý gốc!", 3)
        elseif cmdName == "setcoregui" or cmdName == "hidecoregui" then
            game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.All, false)
        elseif cmdName == "showcoregui" then
            game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.All, true)
        elseif cmdName == "clearentities" then
            for _, v in ipairs(workspace:GetChildren()) do
                if v:IsA("Tool") or v:IsA("BasePart") then v:Destroy() end
            end
        elseif cmdName == "lockworkspace" then
            workspace.Terrain.Anchored = true
        elseif cmdName == "unlockworkspace" then
            workspace.Terrain.Anchored = false
        elseif cmdName == "speedboost" and hum then
            local old = hum.WalkSpeed
            hum.WalkSpeed = old + 50
            task.spawn(function() task.wait(2) hum.WalkSpeed = old end)
        elseif cmdName == "flyspeedboost" then
            flySpeed = flySpeed + 100
            task.spawn(function() task.wait(2) flySpeed = flySpeed - 100 end)
        elseif cmdName == "clickdelete" then
            local tool = Instance.new("Tool")
            tool.Name = "Delete Tool"
            tool.RequiresHandle = false
            tool.Activated:Connect(function()
                local mouse = LocalPlayer:GetMouse()
                if mouse.Target then mouse.Target:Destroy() end
            end)
            tool.Parent = LocalPlayer.Backpack
        elseif cmdName == "view" then
            local targets = getTargetPlayer(args[1])
            if targets[1] and targets[1].Character then
                Camera.CameraSubject = targets[1].Character:FindFirstChildOfClass("Humanoid")
            end
        elseif cmdName == "unview" and hum then
            Camera.CameraSubject = hum
        elseif cmdName == "infyield" then
            loadstring(game:HttpGet("https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source"))()
        elseif cmdName == "loaddex" then
            loadstring(game:HttpGet("https://raw.githubusercontent.com/Babyhamsta/RBLX_Playground/main/DexExplorer.lua"))()
        elseif cmdName == "loadspy" then
            loadstring(game:HttpGet("https://raw.githubusercontent.com/exxtremestuffs/SimpleSpySource/master/SimpleSpy.lua"))()
        else
            InfoText.Text = "Lệnh đã chạy thành công: " .. cmdName
        end
    end)
end

-- ==================== SORT AND POPULATE LIST VISUALLY ====================
local sortedList = {}
for name, data in pairs(commands) do
    if not sortedList[data.desc] then
        sortedList[data.desc] = {}
    end
    -- Keep registry names unique
    local exists = false
    for _, existingName in ipairs(sortedList[data.desc]) do
        if existingName == name then exists = true break end
    end
    if not exists then
        table.insert(sortedList[data.desc], name)
    end
end

for desc, names in pairs(sortedList) do
    addCommandToUI(names, desc)
end

-- ==================== COMMAND PARSER & EXECUTION ====================
local function executeCommand(inputStr)
    if inputStr == "" then return end
    local parts = {}
    for word in inputStr:gmatch("%S+") do
        table.insert(parts, word)
    end

    local cmdName = table.remove(parts, 1):lower()
    local cmd = commands[cmdName]

    if cmd then
        local success, err = pcall(function()
            cmd.handler(parts)
        end)
        if success then
            InfoText.TextColor3 = Color3.fromRGB(0, 255, 120)
            InfoText.Text = "Lệnh [" .. cmdName .. "] thực thi thành công."
        else
            InfoText.TextColor3 = Color3.fromRGB(255, 75, 75)
            InfoText.Text = "Lỗi lệnh: " .. tostring(err)
        end
    else
        if cmdName == "help" then
            InfoText.TextColor3 = Color3.fromRGB(255, 255, 255)
            InfoText.Text = "Danh sách lệnh đã hiển thị ở cuộn bên dưới."
        else
            InfoText.TextColor3 = Color3.fromRGB(255, 150, 0)
            InfoText.Text = "Không tìm thấy lệnh '" .. cmdName .. "'. Thử gõ 'help'"
        end
    end
end

-- Box Focus Lost Execution
ConsoleInput.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local text = ConsoleInput.Text
        executeCommand(text)
        ConsoleInput.Text = "" -- Clear for next command
        SuggestionBox.Visible = false
    end
end)
