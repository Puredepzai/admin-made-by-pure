-- Rebuild the UI command listing for optimized searching performance
task.spawn(function()
    task.wait(1.5)
    pcall(function()
        for _, child in ipairs(ScrollContainer:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end
        
        local newList = {}
        local tIdx = 1
        local descMap = {}
        
        for n, data in pairs(commands) do
            local d = data.desc
            if not descMap[d] then
                descMap[d] = tIdx
                newList[tIdx] = { desc = d, names = {} }
                tIdx = tIdx + 1
            end
            local grp = newList[descMap[d]]
            table.insert(grp.names, n)
        end
        
        for i = 1, #newList do
            local cmdData = newList[i]
            addCommandToUI(cmdData.names, cmdData.desc)
        end
    end)
end)
