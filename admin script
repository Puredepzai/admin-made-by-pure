addCommand({"walkfling", "wf"}, "Bật chế độ chạm là bay (Walk Fling)", function()
    walkFlingActive = not walkFlingActive
    if walkFlingActive then
        notify("Walk Fling", "Chế độ chạm là bay đã được BẬT!", 3)
        task.spawn(function()
            while walkFlingActive do
                RunService.Heartbeat:Wait()
                local char = LocalPlayer.Character
                if char then
                    local hrp = getRoot(char)
                    if hrp then
                        hrp.CanCollide = false
                        local oldVel = hrp.Velocity
                        hrp.Velocity = Vector3.new(0, 10000, 0)
                        RunService.RenderStepped:Wait()
                        hrp.Velocity = oldVel
                    end
                    for _, child in ipairs(char:GetDescendants()) do
                        if child:IsA("BasePart") then
                            child.CanCollide = false
                        end
                    end
                end
            end
        end)
    else
        notify("Walk Fling", "Chế độ chạm là bay đã TẮT!", 3)
    end
end)

