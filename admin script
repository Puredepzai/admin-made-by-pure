local function getSafeParent()
    local success, result = pcall(gethui)
    if success and result and typeof(result) == "Instance" then return result end

    local success2, result2 = pcall(game.GetService, game, "CoreGui")
    if success2 and result2 and typeof(result2) == "Instance" then return result2 end

