-- Validate and write custom background asset configuration
local function verifyAndApplyBg(text)
    text = text:gsub("%s+", "")
    local assetId = tonumber(text)

    if assetId then
       BgStatusLabel.Text = "Đang kiểm tra hình ảnh..."
       BgStatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)

       task.spawn(function()
           local success, assetInfo = pcall(function()
               return MarketplaceService:GetProductInfo(assetId)
           end)

           local actualImageId = getRawImageId(assetId) or assetId

           if success and assetInfo then
               BackgroundImage.Image = "rbxassetid://" .. actualImageId
               BackgroundImage.BackgroundTransparency = 0.8
               safeWriteFile(FileConfig, tostring(assetId))
               BgStatusLabel.Text = "Đã áp dụng hình nền thành công"
               BgStatusLabel.TextColor3 = Color3.fromRGB(0, 220, 120)
           else
               if actualImageId then
                   BackgroundImage.Image = "rbxassetid://" .. actualImageId
                   BackgroundImage.BackgroundTransparency = 0.8
                   safeWriteFile(FileConfig, tostring(assetId))
                   BgStatusLabel.Text = "Đã áp dụng hình nền"
                   BgStatusLabel.TextColor3 = Color3.fromRGB(0, 220, 120)
               else
                   BackgroundImage.Image = ""
                   BackgroundImage.BackgroundTransparency = 1
                   BgStatusLabel.Text = "ID Hình ảnh không hợp lệ"
                   BgStatusLabel.TextColor3 = Color3.fromRGB(255, 75, 75)
               end
           end
       end)
    else
       BackgroundImage.Image = ""
       BackgroundImage.BackgroundTransparency = 1
       safeDelFile(FileConfig)
       BgStatusLabel.Text = "Đã xóa hình nền tùy biến"
       BgStatusLabel.TextColor3 = Color3.fromRGB(255, 75, 75)
    end
end

