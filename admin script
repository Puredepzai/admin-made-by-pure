local function safeIsFile(path)
    local s, r = pcall(function() return isfile and isfile(path) end)
    return s and r
end

local function safeReadFile(path)
    local s, r = pcall(function() return readfile and readfile(path) end)
    return s and r or ""
end

local function safeWriteFile(path, content)
    pcall(function() if writefile then writefile(path, content) end end)
end

local function safeDelFile(path)
    pcall(function() if delfile then delfile(path) end end)
end

