-- Resolve Player Target Helper
local function getTargetPlayer(text)
    if not text or text == "" then return {LocalPlayer} end
    if text:lower() == "all" then return Players:GetPlayers() end
    if text:lower() == "others" then
        local others = {}
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then table.insert(others, p) end
        end
        return others
    end
    if text:lower() == "me" then return {LocalPlayer} end

    local matches = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #text) == text:lower() or p.DisplayName:lower():sub(1, #text) == text:lower() then
            table.insert(matches, p)
        end
    end
    return matches
end

-- Input Autocomplete Logic (Supports Multi-gợi ý / Multi-suggestions)
local currentFirstMatch = nil
ConsoleInput:GetPropertyChangedSignal("Text"):Connect(function()
    local text = ConsoleInput.Text
    if text == "" then
        SuggestionLabel.Text = ""
        currentFirstMatch = nil
        return
    end

    local args = text:split(" ")
    local inputCmd = args[1]:lower()

    local matches = {}
    for name, _ in pairs(commands) do
        if name:sub(1, #inputCmd) == inputCmd then
            table.insert(matches, name)
        end
    end

    if #matches > 0 then
        table.sort(matches)
        currentFirstMatch = matches[1]
        
        -- Generate multiple suggestions listing
        local displayMatches = {}
        for i = 1, math.min(#matches, 6) do
            table.insert(displayMatches, matches[i])
        end
        local matchStr = table.concat(displayMatches, ", ")
        if #matches > 6 then
            matchStr = matchStr .. "..."
        end
        
        SuggestionLabel.Text = "Gợi ý: " .. matchStr
    else
        SuggestionLabel.Text = ""
        currentFirstMatch = nil
    end
end)

-- Auto Fill Suggestion with Tab / Custom Key
UserInputService.InputBegan:Connect(function(input, processed)
    if ConsoleInput:IsFocused() and input.KeyCode == Enum.KeyCode.Tab then
        if currentFirstMatch then
            ConsoleInput.Text = currentFirstMatch
            ConsoleInput.CursorPosition = #ConsoleInput.Text + 1
        end
    end
end)

-- ==================== NO-BUG MOBILE FLY ENGINE ====================
local flyConnection = nil
local flyVelocity = nil
local flyGyro = nil

local function stopFly()
    flyActive = false
    if flyConnection then
        flyConnection:Disconnect()
        flyConnection = nil
    end
    pcall(function()
        if flyVelocity then flyVelocity:Destroy() flyVelocity = nil end
        if flyGyro then flyGyro:Destroy() flyGyro = nil end
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.PlatformStand = false
        end
    end)
end

-- Robust Mobile Velocity Setter
local function setLinearVelocity(part, vel)
    pcall(function()
        part.AssemblyLinearVelocity = vel
    end)
    pcall(function()
        part.Velocity = vel
    end)
end

local function startFly()
    stopFly()
    
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    
    flyActive = true
    hum.PlatformStand = true
    
    flyVelocity = Instance.new("BodyVelocity")
    flyVelocity.Name = "PureAdmin_FlyVelocity"
    flyVelocity.Velocity = Vector3.new(0, 0, 0)
    flyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    flyVelocity.Parent = hrp
    
    flyGyro = Instance.new("BodyGyro")
    flyGyro.Name = "PureAdmin_FlyGyro"
    flyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    flyGyro.CFrame = hrp.CFrame
    flyGyro.Parent = hrp
    
    flyConnection = RunService.Heartbeat:Connect(function()
        local currentCharacter = LocalPlayer.Character
        if not currentCharacter or not currentCharacter.Parent then
            stopFly()
            return
        end
        local currentHrp = currentCharacter:FindFirstChild("HumanoidRootPart")
        local currentHum = currentCharacter:FindFirstChildOfClass("Humanoid")
        if not currentHrp or not currentHum then return end
        
        currentHum.PlatformStand = true
        local moveDirection = currentHum.MoveDirection
        local camCFrame = Camera.CFrame
        local velocity = Vector3.new(0, 0, 0)
        
        if moveDirection.Magnitude > 0 then
            local localMove = camCFrame:VectorToObjectSpace(moveDirection)
            local flyDir = (camCFrame.LookVector * -localMove.Z) + (camCFrame.RightVector * localMove.X)
            if flyDir.Magnitude > 0 then
                flyDir = flyDir.Unit
            end
            velocity = flyDir * flySpeed
        else
            velocity = Vector3.new(0, 0, 0)
        end
        
        if flyBypassActive then
            setLinearVelocity(currentHrp, velocity)
            currentHrp.CFrame = currentHrp.CFrame + (velocity * 0.016)
            if flyVelocity then
                flyVelocity.Velocity = velocity
            end
        else
            setLinearVelocity(currentHrp, velocity)
            if flyVelocity then
                flyVelocity.Velocity = velocity
            end
        end
        
        if flyGyro then
            flyGyro.CFrame = camCFrame
        end
    end)
end

LocalPlayer.CharacterAdded:Connect(function()
    if flyActive then
        task.wait(0.5)
        startFly()
    end
end)

-- ==================== PHYSICS & TARGET FLING LOGIC (SKIDFLING CORE) ====================
local function SkidFling(TargetPlayer)
    if not TargetPlayer or TargetPlayer == LocalPlayer then return end
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    
    local targetChar = TargetPlayer.Character
    local targetHrp = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
    local targetHum = targetChar and targetChar:FindFirstChildOfClass("Humanoid")
    
    if not hrp or not targetHrp or getgenv().FlingActive then return end
    
    getgenv().FlingActive = true
    getgenv().OldPos = hrp.CFrame
    
    local oldFallenHeight = workspace.FallenPartsDestroyHeight
    pcall(function()
        workspace.FallenPartsDestroyHeight = 0/0
    end)
    
    Camera.CameraSubject = targetHum or targetChar:FindFirstChild("Head") or targetHrp
    notify("SkidFling", "Đang Fling mục tiêu: " .. TargetPlayer.DisplayName, 2)
    
    local parts = {}
    for _, v in ipairs(char:GetDescendants()) do
        if v:IsA("BasePart") then
            table.insert(parts, v)
            v.CanCollide = false
        end
    end
    
    local steppedConn = RunService.Stepped:Connect(function()
        for _, p in ipairs(parts) do
            if p.Parent then p.CanCollide = false end
        end
    end)
    
    local startTime = tick()
    repeat
        RunService.Heartbeat:Wait()
        if not targetHrp or not targetHrp.Parent or not targetHum or targetHum.Health <= 0 then break end
        if not hrp or not hrp.Parent then break end
        
        pcall(function()
            hrp.Velocity = Vector3.new(9e7, 9e7, 9e7)
            hrp.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
            hrp.AssemblyLinearVelocity = Vector3.new(9e7, 9e7, 9e7)
            hrp.AssemblySpreadVelocity = Vector3.new(9e8, 9e8, 9e8)
        end)
        
        hrp.CFrame = targetHrp.CFrame * CFrame.new(math.random(-150, 150)/100, 0, math.random(-150, 150)/100)
    until not getgenv().FlingActive or (tick() - startTime > 2) or not TargetPlayer.Parent
    
    steppedConn:Disconnect()
    getgenv().FlingActive = false
    
    if hrp and hrp.Parent then
        pcall(function()
            hrp.Velocity = Vector3.new(0, 0, 0)
            hrp.RotVelocity = Vector3.new(0, 0, 0)
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        end)
        hrp.CFrame = getgenv().OldPos
    end
    
    if hum and hum.Parent then
        Camera.CameraSubject = hum
    end
    
    pcall(function()
        workspace.FallenPartsDestroyHeight = oldFallenHeight
    end)
    
    notify("SkidFling", "Fling hoàn tất hoặc đã dừng!", 2)
end

