end

local tr, tg, tb = currentSettings.TextColor:match("(%d+),%s*(%d+),%s*(%d+)")
if tr and tg and tb then
    applyNewTextColor(Color3.fromRGB(tonumber(tr), tonumber(tg), tonumber(tb)), true)
end

local op = tonumber(currentSettings.Opacity)
if op then
    applyOpacity(op)
end
end)
