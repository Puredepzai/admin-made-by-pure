-- ==================== CHATTED EVENT LISTENER ====================
local function handleChatted(msg)
    local raw = msg:lower()
    if raw:sub(1, 9) == "/e fling " then
        local targetName = msg:sub(10)
        local targets = getTargetPlayer(targetName)
        if #targets > 0 then
            task.spawn(function()
                SkidFling(targets[1])
            end)
        end
    elseif raw == "/e flingall" then
        task.spawn(function()
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer then
                    SkidFling(p)
                    task.wait(0.2)
                end
            end
        end)
    elseif raw == "/e unfling" or raw == "/e stopfling" then
        getgenv().FlingActive = false
    end
end

LocalPlayer.Chatted:Connect(handleChatted)

-- ==================== SORT AND POPULATE LIST VISUALLY ====================
local sortedList = {}
local trackerIndex = 1
local descToId = {}

for name, data in pairs(commands) do
    local desc = data.desc
    if not descToId[desc] then
        descToId[desc] = trackerIndex
        sortedList[trackerIndex] = { desc = desc, names = {} }
        trackerIndex = trackerIndex + 1
    end
    local targetGroup = sortedList[descToId[desc]]
    table.insert(targetGroup.names, name)
end

for i = 1, #sortedList do
    local commandData = sortedList[i]
    addCommandToUI(commandData.names, commandData.desc)
end

-- ==================== COMMAND PARSER & EXECUTION ====================
local function executeCommand(inputStr)
    if inputStr == "" then return end
    local parts = {}
    for word in inputStr:gmatch("%S+") do
        table.insert(parts, word)
    end

    local cmdName = table.remove(parts, 1):lower()
    local cmd = commands[cmdName]

    if cmd then
        local success, err = pcall(function()
            cmd.handler(parts)
        end)
        if success then
            InfoText.TextColor3 = Color3.fromRGB(0, 255, 120)
            InfoText.Text = "Lб»Үnh [" .. cmdName .. "] thб»ұc thi thГ nh cГҙng."
        else
            InfoText.TextColor3 = Color3.fromRGB(255, 75, 75)
            InfoText.Text = "Lб»—i lб»Үnh: " .. tostring(err)
        end
    else
        if cmdName == "help" then
            InfoText.TextColor3 = Color3.fromRGB(255, 255, 255)
            InfoText.Text = "Danh sГЎch lб»Үnh Д‘ГЈ hiб»ғn thб»Ӣ б»ҹ cuб»ҷn bГӘn dЖ°б»ӣi."
        else
            InfoText.TextColor3 = Color3.fromRGB(255, 150, 0)
            InfoText.Text = "KhГҙng tГ¬m thбәҘy lб»Үnh '" .. cmdName .. "'. Thб»ӯ gГө 'help'"
        end
    end
end

-- Box Focus Lost Execution
