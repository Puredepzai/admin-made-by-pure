-- 1. Anti-Fling
local antiFlingActive = false
local antiFlingConnection = nil

local function toggleAntiFling(state)
    antiFlingActive = state
    if antiFlingActive then
        antiFlingConnection = RunService.Stepped:Connect(function()
            local char = LocalPlayer.Character
            if not char then return end
            
            -- Prevent self from building dangerous physics forces
            for _, item in ipairs(char:GetDescendants()) do
                if item:IsA("BasePart") then
                    item.Velocity = Vector3.new(0,0,0)
                    item.RotVelocity = Vector3.new(0,0,0)
                end
            end
            
            -- Disable physical collisions from foreign characters locally
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    for _, part in ipairs(player.Character:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end
                end
            end
        end)
        notify("Anti-Fling", "Đã bật chế độ chống bị văng (Anti-Fling)!", 3)
    else
        if antiFlingConnection then
            antiFlingConnection:Disconnect()
            antiFlingConnection = nil
        end
        notify("Anti-Fling", "Đã tắt chống văng!", 3)
    end
end

