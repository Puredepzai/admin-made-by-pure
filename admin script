local function setJointAngle(joint, c0Offset)
    if not joint then return end
    if not originalC0s[joint] then
        originalC0s[joint] = joint.C0
    end
    joint.C0 = originalC0s[joint] * c0Offset
end

local function resetJoints()
    for joint, origC0 in pairs(originalC0s) do
        if joint and joint.Parent then
            joint.C0 = origC0
        end
    end
    originalC0s = {}
end

-- Safe getter for R6 and R15 joints
local function getJoints()
    local char = LocalPlayer.Character
    if not char then return {} end
    local joints = {}
    if char:FindFirstChild("Torso") then -- R6
        joints.neck = char.Torso:FindFirstChild("Neck")
        joints.leftShoulder = char.Torso:FindFirstChild("Left Shoulder")
        joints.rightShoulder = char.Torso:FindFirstChild("Right Shoulder")
        joints.leftHip = char.Torso:FindFirstChild("Left Hip")
        joints.rightHip = char.Torso:FindFirstChild("Right Hip")
    elseif char:FindFirstChild("LeftUpperArm") then -- R15
        joints.neck = char.Head:FindFirstChild("Neck")
        joints.leftShoulder = char.LeftUpperArm:FindFirstChild("LeftShoulder")
        joints.rightShoulder = char.RightUpperArm:FindFirstChild("RightShoulder")
        joints.leftHip = char.LeftUpperLeg:FindFirstChild("LeftHip")
        joints.rightHip = char.RightUpperLeg:FindFirstChild("RightHip")
    end
    return joints
end

