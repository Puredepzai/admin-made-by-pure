    -- LuГҙn tГӯnh tГўm mГ n hГ¬nh б»ҹ Д‘Гўy
    local centerPosition = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    if FOVCircle then
        FOVCircle.Radius = aimbotRadius
        FOVCircle.Position = centerPosition -- Гүp vГІng trГІn Д‘б»Ҹ nбәұm im б»ҹ giб»Ҝa mГ n hГ¬nh
        FOVCircle.Visible = aimbotActive
    end

    if aimbotActive then
        local target = getClosestPlayerToCenter()
        if target then
            -- Tб»ұ Д‘б»ҷng quay camera thбәіng vГ o mб»Ҙc tiГӘu
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position)
        end
    end
end)


