           hum.JumpHeight = 7.2
           hum.JumpPower = 50
           hum.UseJumpPower = true
       end
       local controls = LocalPlayer:FindFirstChild("PlayerScripts"):FindFirstChild("PlayerModule")
       if controls then
           local activeController = require(controls):GetControls()
           if activeController then
               activeController:Enable(true)
           end
       end
   end)
end

