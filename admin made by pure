local function executeCommand(inputStr)
    if inputStr == "" then return end
    local parts = {}
    for word in inputStr:gmatch("%S+") do table.insert(parts, word) end
    local cmdName = table.remove(parts, 1):lower()
    local cmd = commands[cmdName]
    if cmd then
        local success, err = pcall(function() cmd.handler(parts) end)
        if success then
            InfoText.TextColor3 = Color3.fromRGB(0, 255, 120)
            InfoText.Text = "ńź√£ thŠĽĪc thi th√†nh c√īng lŠĽánh: [" .. cmdName .. "]"
        else
            InfoText.TextColor3 = Color3.fromRGB(255, 75, 75)
            InfoText.Text = "Ph√°t hiŠĽán lŠĽói xŠĽ≠ l√Ĺ: " .. tostring(err)
        end
    else
        if cmdName == "help" then
            InfoText.TextColor3 = Color3.fromRGB(255, 255, 255)
            InfoText.Text = "ChŠĽćn danh s√°ch lŠĽánh hŠĽĮu dŠĽ•ng tŠĽę bŠļ£ng c√†i ńĎŠļ∑t phŠĽ• b√™n phŠļ£i."
        else
            InfoText.TextColor3 = Color3.fromRGB(255, 150, 0)
            InfoText.Text = "LŠĽánh '" .. cmdName .. "' hiŠĽán tŠļ°i ch∆įa k√≠ch hoŠļ°t hoŠļ∑c nhŠļ≠p sai c√ļ ph√°p."
        end
    end
end

ConsoleInput.FocusLost:Connect(function(enterPressed)
