-- =======================================================
addCommand({"antilag", "potato", "boost"}, "Siêu tối ưu FPS, dọn RAM, mở khóa FPS và xóa hiệu ứng", function()
    potatoActive = true
    notify("Tối Ưu Hệ Thống", "Đang tiến hành dọn dẹp RAM & Tăng tốc độ khung hình...", 4)
    
    -- 1. Mở khóa FPS và tinh chỉnh luồng xử lý luân phiên của Roblox Engine
    pcall(function()
        if setfpscap then setfpscap(999) end
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        game:GetService("RunService"):Set3dRenderingEnabled(true)
    end)
    
    -- 2. Dọn rác bộ nhớ RAM Client ngầm
    pcall(function()
        gcinfo() -- Giải phóng Garbage Collection ép buộc dọn RAM ngay lập tức
    end)
    
    -- 3. Xóa triệt để mọi hiệu ứng môi trường nặng gây drop khung hình
    pcall(function()
        Lighting:ClearAllChildren()
        local terrain = workspace:FindFirstChildOfClass("Terrain")
        if terrain then
            terrain.WaterWaveSize = 0
            terrain.WaterWaveSpeed = 0
            terrain.WaterReflectance = 0
            terrain.WaterTransparency = 0
        end
    end)
    
    -- 4. Loại bỏ Texture, Decal, Hiệu ứng hạt trên diện rộng để giải phóng GPU
    local function cleanInstance(v)
        if v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") or v:IsA("Trail") 
        or v:IsA("Sparkles") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Explosion") then
            v:Destroy()
        elseif v:IsA("BasePart") and not v:IsA("MeshPart") then
            v.Material = Enum.Material.SmoothPlastic
            v.Reflectance = 0
            pcall(function() v.TextureID = "" end)
        elseif v:IsA("MeshPart") then
            v.Material = Enum.Material.SmoothPlastic
            v.Reflectance = 0
            pcall(function() v.TextureID = "" end)
            pcall(function() v.MeshId = "" end)
        end
    end

    for _, v in pairs(workspace:GetDescendants()) do
        cleanInstance(v)
    end
    
    -- Tự động tối ưu các vật thể mới được sinh ra sau này
    workspace.DescendantAdded:Connect(function(val)
        if potatoActive then
            pcall(function() cleanInstance(val) end)
        end
    end)

    notify("Potato Mode", "ĐÃ TỐI ƯU SIÊU MƯỢT! Đồ họa đã được nén về mức tối giản.", 4)
end)


