local function getSafeParent()
    local success, result = pcall(gethui)
    if success and result and typeof(result) == "Instance" then return result end

    local success2, result2 = pcall(game.GetService, game, "CoreGui")
    if success2 and result2 and typeof(result2) == "Instance" then return result2 end

    local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui") or LocalPlayer:WaitForChild("PlayerGui", 15)
    return playerGui
end

local CoreGui = getSafeParent()

-- Safe file operations helpers
local function safeIsFile(path)
    local s, r = pcall(function() return isfile and isfile(path) end)
    return s and r
end

local function safeReadFile(path)
    local s, r = pcall(function() return readfile and readfile(path) end)
    return s and r or ""
end

local function safeWriteFile(path, content)
    pcall(function() if writefile then writefile(path, content) end end)
end

local function safeDelFile(path)
    pcall(function() if delfile then delfile(path) end end)
end

