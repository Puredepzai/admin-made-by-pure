    if freecamActive then
       freecamActive = false
       if freecamConnection then freecamConnection:Disconnect() freecamConnection = nil end
       Camera.CameraType = Enum.CameraType.Custom
       local j = PureAdminGUI:FindFirstChild("FreeCamJoystick")
       if j then j:Destroy() end
       notify("FreeCam", "ńź√£ tŠļĮt FreeCam", 2)
       return
    end

    freecamActive = true
    Camera.CameraType = Enum.CameraType.Scriptable
    local camCFrame = Camera.CFrame
    freecamPos = camCFrame.Position
    freecamRotX, freecamRotY = camCFrame:ToEulerAnglesYXZ()

    local Joystick = Instance.new("Frame")
    Joystick.Name = "FreeCamJoystick"
    Joystick.Parent = PureAdminGUI
    Joystick.Size = UDim2.new(0, 150, 0, 150)
    Joystick.Position = UDim2.new(0.05, 0, 0.6, 0)
    Joystick.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Joystick.BackgroundTransparency = 0.5

    local Circle = Instance.new("UICorner")
    Circle.CornerRadius = UDim.new(1, 0)
    Circle.Parent = Joystick

    local moveVec = Vector3.new(0, 0, 0)
    Joystick.InputChanged:Connect(function(input)
       if input.UserInputType == Enum.UserInputType.Touch then
           local pos = input.Position
           local center = Joystick.AbsolutePosition + Joystick.AbsoluteSize/2
           local delta = (Vector2.new(pos.X, pos.Y) - center) / 75
           moveVec = Vector3.new(delta.X, 0, delta.Y)
       end
    end)

    freecamConnection = RunService.RenderStepped:Connect(function(dt)
       if not freecamActive then return end
       
       local kbMove = Vector3.new(0, 0, 0)
       if UserInputService:IsKeyDown(Enum.KeyCode.W) then kbMove = kbMove + Vector3.new(0, 0, -1) end
       if UserInputService:IsKeyDown(Enum.KeyCode.S) then kbMove = kbMove + Vector3.new(0, 0, 1) end
       if UserInputService:IsKeyDown(Enum.KeyCode.A) then kbMove = kbMove + Vector3.new(-1, 0, 0) end
       if UserInputService:IsKeyDown(Enum.KeyCode.D) then kbMove = kbMove + Vector3.new(1, 0, 0) end
       if UserInputService:IsKeyDown(Enum.KeyCode.E) then freecamPos = freecamPos + Vector3.new(0, 1, 0) end
       if UserInputService:IsKeyDown(Enum.KeyCode.Q) then freecamPos = freecamPos + Vector3.new(0, -1, 0) end

       local finalMove = kbMove.Magnitude > 0 and kbMove.Unit or moveVec
       local currentSpeed = 50 * dt
       local lookCF = CFrame.Angles(0, freecamRotY, 0) * CFrame.Angles(freecamRotX, 0, 0)
       freecamPos = freecamPos + lookCF:VectorToWorldSpace(finalMove) * currentSpeed
       Camera.CFrame = CFrame.new(freecamPos) * lookCF
    end)

    local isRotating = false
    local lastInputPos = nil
    UserInputService.InputBegan:Connect(function(input, processed)
       if not processed and (input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.Touch) then
           isRotating = true
           lastInputPos = input.Position
       end
    end)
    UserInputService.InputEnded:Connect(function(input)
       if input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.Touch then
           isRotating = false
           lastInputPos = nil
       end
    end)
    UserInputService.InputChanged:Connect(function(input)
       if isRotating and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
           if lastInputPos then
               local delta = input.Position - lastInputPos
               freecamRotX = freecamRotX - delta.Y * 0.005
               freecamRotY = freecamRotY - delta.X * 0.005
               lastInputPos = input.Position
           end
       end
    end)

    notify("FreeCam", "ńź√£ bŠļ≠t! WASD ńĎŠĽÉ di chuyŠĽÉn, chuŠĽôt phŠļ£i/vuŠĽĎt m√†n h√¨nh ńĎŠĽÉ xoay.", 3)
end)

