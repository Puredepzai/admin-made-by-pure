       local bloom = Lighting:FindFirstChild("PureRTX_Bloom") or Instance.new("BloomEffect", Lighting)
       bloom.Name = "PureRTX_Bloom"
       bloom.Intensity = 1
       bloom.Size = 24
       bloom.Threshold = 0.9

       local colorCorrection = Lighting:FindFirstChild("PureRTX_ColorCorr") or Instance.new("ColorCorrectionEffect", Lighting)
       colorCorrection.Name = "PureRTX_ColorCorr"
       colorCorrection.Contrast = 0.15
       colorCorrection.Saturation = 0.2
       colorCorrection.TintColor = Color3.fromRGB(255, 245, 235)

       local sunRays = Lighting:FindFirstChild("PureRTX_SunRays") or Instance.new("SunRaysEffect", Lighting)
       sunRays.Name = "PureRTX_SunRays"
       sunRays.Intensity = 0.1
       sunRays.Spread = 0.8
   else
       pcall(function()
           if Lighting:FindFirstChild("PureRTX_Bloom") then Lighting.PureRTX_Bloom:Destroy() end
           if Lighting:FindFirstChild("PureRTX_ColorCorr") then Lighting.PureRTX_ColorCorr:Destroy() end
           if Lighting:FindFirstChild("PureRTX_SunRays") then Lighting.PureRTX_SunRays:Destroy() end
       end)
   end
end

