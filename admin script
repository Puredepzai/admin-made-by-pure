local function handleChatted(msg)
    local raw = msg:lower()
    if raw:sub(1, 9) == "/e fling " then
       local targetName = msg:sub(10)
       local targets = getTargetPlayer(targetName)
       if #targets > 0 then
           task.spawn(function()
               SkidFling(targets[1])
           end)
       end
    elseif raw == "/e flingall" then
       task.spawn(function()
           for _, p in ipairs(Players:GetPlayers()) do
               if p ~= LocalPlayer then
                   SkidFling(p)
                   task.wait(0.2)
               end
           end
       end)
    elseif raw == "/e unfling" or raw == "/e stopfling" then
       getgenv().FlingActive = false
    end
end

