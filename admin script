-- Autocomplete Logic
ConsoleInput:GetPropertyChangedSignal("Text"):Connect(function()
    local text = ConsoleInput.Text:lower()
    if text == "" then
        SuggestionBox.Visible = false
        return
    end

    local found = {}
    for cmdName, info in pairs(commands) do
        if cmdName:sub(1, #text) == text then
            table.insert(found, cmdName)
        end
    end

    if #found > 0 then
        table.sort(found)
        SuggestionBox.Visible = true
        SuggestionText.Text = "Gợi ý: " .. table.concat(found, ", ")
    else
        SuggestionBox.Visible = false
    end
end)

