-- ESP ĐỊNH VỊ & TEAM ESP
-- =======================================================
local function createNameESP(player, color)
    if player == LocalPlayer then return end
    local char = player.Character
    if not char then return end
    local head = char:WaitForChild("Head", 5)
    if not head then return end
    local billboard = head:FindFirstChild("PureNameESP")
    if not billboard then
        billboard = Instance.new("BillboardGui")
        billboard.Name = "PureNameESP"
        billboard.Size = UDim2.new(0, 150, 0, 30)
        billboard.AlwaysOnTop = true
        billboard.StudsOffset = Vector3.new(0, 2.5, 0)
        billboard.Parent = head
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.TextColor3 = color or getgenv().ThemeColor
        label.TextStrokeTransparency = 0.2
        label.Font = Enum.Font.GothamBold
        label.TextSize = 10
        label.Text = player.DisplayName .. " (@" .. player.Name .. ")"
        label.Parent = billboard
    end
end

local function removeNameESP(player)
    if player.Character and player.Character:FindFirstChild("Head") then
        local esp = player.Character.Head:FindFirstChild("PureNameESP")
        if esp then esp:Destroy() end
    end
end

