        if Camera.CameraType == Enum.CameraType.Scriptable then
            camPos = camPos + (Camera.CFrame.LookVector * -moveVec.Z) + (Camera.CFrame.RightVector * moveVec.X)
            Camera.CFrame = CFrame.new(camPos, camPos + Camera.CFrame.LookVector)
        end
    end)
    notify("FreeCam", "Đã bật! Dùng Joystick bên trái để bay.", 3)
