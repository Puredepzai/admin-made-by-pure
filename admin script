-- ==================== SORT AND POPULATE LIST VISUALLY ====================
-- This loop is placed at the very bottom to guarantee all dynamically registered 
-- commands (including new, batch, custom ones) are visualised properly inside the Left UI column.
local sortedList = {}
local trackerIndex = 1
local descToId = {}

for name, data in pairs(commands) do
local desc = data.desc
if not descToId[desc] then
    descToId[desc] = trackerIndex
    sortedList[trackerIndex] = { desc = desc, names = {} }
    trackerIndex = trackerIndex + 1
end
local targetGroup = sortedList[descToId[desc]]
table.insert(targetGroup.names, name)
end

for i = 1, #sortedList do
local commandData = sortedList[i]
addCommandToUI(commandData.names, commandData.desc)
end


-- Apply Loaded Theme and Configuration immediately on launch
pcall(function()
local r, g, b = currentSettings.ThemeColor:match("(%d+),%s*(%d+),%s*(%d+)")
