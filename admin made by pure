-- Potato Mode: X√≥a sŠļ°ch Texture, Skybox, Atmosphere, Decal, Skin/QuŠļßn √°o
local function activatePotatoMode()
    potatoActive = true
    pcall(function()
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Sparkles") then
                v:Destroy()
            elseif v:IsA("BasePart") then
                v.Material = Enum.Material.SmoothPlastic
                pcall(function() v.TextureID = "" end)
            elseif v:IsA("Shirt") or v:IsA("Pants") or v:IsA("ShirtGraphic") or v:IsA("CharacterMesh") then
                v:Destroy()
            end
        end
        Lighting:ClearAllChildren()
        local terrain = workspace:FindFirstChildOfClass("Terrain")
        if terrain then
            terrain.WaterWaveSize = 0
            terrain.WaterWaveSpeed = 0
            terrain.WaterReflectance = 0
            terrain.WaterTransparency = 0
        end
        settings().Rendering.QualityLevel = 1
    end)
    notify("Potato Mode", "ńź√£ tŠĽĎi ∆įu h√≥a si√™u m∆įŠĽ£t!", 3)
end

