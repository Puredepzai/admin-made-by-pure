local customJumpBtn = nil

local function toggleCustomJumpButton(state)
    if state then
        if customJumpBtn then customJumpBtn.Visible = true return end
        
        customJumpBtn = Instance.new("TextButton")
        customJumpBtn.Name = "PA_MobileJump"
        customJumpBtn.Parent = PureAdminGUI
        customJumpBtn.Size = UDim2.new(0, 65, 0, 65)
        customJumpBtn.Position = UDim2.new(0.85, -20, 0.6, 0)
        customJumpBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        customJumpBtn.BorderSizePixel = 0
        customJumpBtn.Text = "JUMP"
        customJumpBtn.Font = Enum.Font.GothamBold
        customJumpBtn.TextSize = 14
        customJumpBtn.TextColor3 = Color3.fromRGB(240, 240, 240)
        customJumpBtn.ZIndex = 10
        makeDraggable(customJumpBtn)

        local Corner = Instance.new("UICorner")
        Corner.CornerRadius = UDim.new(0, 32.5)
        Corner.Parent = customJumpBtn

        local Stroke = Instance.new("UIStroke")
        Stroke.Enabled = false
        Stroke.Thickness = 0
        Stroke.Parent = customJumpBtn

        customJumpBtn.MouseButton1Down:Connect(function()
            local char = LocalPlayer.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.Jump = true
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end)
    else
        if customJumpBtn then
            customJumpBtn.Visible = false
        end
    end
end

local function unlockDefaultJump()
    pcall(function()
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.JumpHeight = 7.2
            hum.JumpPower = 50
            hum.UseJumpPower = true
        end
        local controls = LocalPlayer:FindFirstChild("PlayerScripts"):FindFirstChild("PlayerModule")
        if controls then
            local activeController = require(controls):GetControls()
            if activeController then
                activeController:Enable(true)
            end
        end
    end)
end

