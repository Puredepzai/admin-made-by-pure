-- Antikick, Antiban & Auto-Rejoin Setup
local function triggerRejoin()
    safeWriteFile("PureCommander_AutoOpen.txt", "true")
    
    -- Setup a Custom GUI overlay on screen before self-kicking
    pcall(function()
        local OverlayScreen = Instance.new("ScreenGui")
        OverlayScreen.Name = "PureRejoinOverlay"
        OverlayScreen.Parent = CoreGui
        
        local Frame = Instance.new("Frame")
        Frame.Size = UDim2.new(1, 0, 1, 0)
        Frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
        Frame.Parent = OverlayScreen
        
        local Label = Instance.new("TextLabel")
        Label.Size = UDim2.new(1, 0, 0, 50)
        Label.Position = UDim2.new(0, 0, 0.5, -25)
        Label.BackgroundTransparency = 1
        Label.Text = "ńźang rejoin..."
        Label.TextColor3 = Color3.fromRGB(255, 255, 255)
        Label.Font = Enum.Font.GothamBold
        Label.TextSize = 24
        Label.Parent = Frame
    end)
    
    task.wait(0.5)
    
    -- Teleport attempt
    pcall(function()
        game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer)
    end)
    
    -- Fast loop attempt in case teleport failed
    task.spawn(function()
        while task.wait(1.5) do
            pcall(function()
                game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer)
            end)
        end
    end)
end


-- Metatable Hooking for local scripts trying to kick
pcall(function()
    if hookmetamethod then
        local oldNamecall
        oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
            local method = getnamecallmethod()
            if self == LocalPlayer and (method == "Kick" or method == "kick") then
                task.spawn(function()
                    if InfoText then InfoText.Text = "ńźang rejoin..." end
                    triggerRejoin()
                end)
                return
            end
            return oldNamecall(self, ...)
        end)
    end
end)

