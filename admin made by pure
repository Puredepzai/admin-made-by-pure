addCommand({"teleportr", "tprandom"}, "Dịch chuyển tức thời tới vị trí một người chơi ngẫu nhiên", function()
    local allPlayers = Players:GetPlayers()
    if #allPlayers > 1 then
        local chosen = allPlayers[math.random(1, #allPlayers)]
        while chosen == LocalPlayer do
            chosen = allPlayers[math.random(1, #allPlayers)]
        end
        local myHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local tHrp = chosen.Character and chosen.Character:FindFirstChild("HumanoidRootPart")
        if myHrp and tHrp then
            myHrp.CFrame = tHrp.CFrame
            notify("Dịch chuyển", "Đcontrol bay tới tọa độ của: " .. chosen.DisplayName, 3)
        end
    else
        notify("Lỗi", "Không có đủ người chơi khác trong phòng.", 3)
    end
end)

