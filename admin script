-- Helper function to convert Decal ID to Image ID reliably on Mobile Executors
local function getRawImageId(assetId)
local convertedAssetId = tonumber(assetId)
if not convertedAssetId then return nil end
local success, result = pcall(function()
    local url = "https://assetdelivery.roblox.com/v1/asset/?id=" .. convertedAssetId
    local content = game:HttpGet(url)
    local imageId = content:match("<url>.-%?id=(%d+)</url>") or content:match("rbxassetid://(%d+)")
    return tonumber(imageId)
end)
if success and result then
    return result
end
return convertedAssetId
end

local function applyBgImage(idStr)
local assetId = tonumber(idStr)
if assetId then
    task.spawn(function()
        local rawId = getRawImageId(assetId) or assetId
        BackgroundImage.Image = "rbxassetid://" .. rawId
        BackgroundImage.BackgroundTransparency = 0.1
    end)
else
    BackgroundImage.Image = ""
    BackgroundImage.BackgroundTransparency = 1
end
end

if safeIsFile(FileConfig) then
local content = safeReadFile(FileConfig)
if content and content ~= "" then
    applyBgImage(content)
end
end

